        <box>
          <size>0.01 0.3 0.1</size>
        </box>
      </geometry>
      <material>
        <ambient>0.5 0.5 0.5 1</ambient>
        <diffuse>0.5 0.5 0.5 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>
    <inertial>
      <mass>0.1</mass>
      <inertia>
        <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz>
      </inertia>
    </inertial>
  </link>
  
  <!-- 右侧墙壁 -->
  <link name='right_wall'>
    <pose>0.15 0 0.005 0 0 0</pose> <!-- Z 坐标调整为 0.005，因为底板厚度变为 0.01 -->
    <collision name='collision_right'>
      <geometry>
        <box>
          <size>0.01 0.3 0.1</size> <!-- 墙壁厚度 0.01m，高度 0.1m -->
        </box>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
        <contact>
