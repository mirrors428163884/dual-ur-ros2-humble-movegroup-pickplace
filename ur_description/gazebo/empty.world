<sdf version='1.7'>
  <world name='default'>
    
    <!-- 原有的光源 -->
    <light name='sun' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose>0 0 10 0 -0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
      <spot>
        <inner_angle>0</inner_angle>
        <outer_angle>0</outer_angle>
        <falloff>0</falloff>
      </spot>
    </light>
    <plugin name="gazebo_link_attacher" filename="libgazebo_link_attacher.so"/>
    
    <!-- ================= START: YAML Defined Object (Original) ================= -->
    <model name='target_plate1564897'>
      <pose>-0.35637 -0.138 0.825 0 0 0</pose>
      <static>0</static>
      <link name='link_left'>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.1 0.1</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e+5</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.1 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.8 1</ambient>
            <diffuse>0.2 0.2 0.8 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.00033</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00017</iyy><iyz>0</iyz><izz>0.00017</izz>
          </inertia>
        </inertial>
      </link>
    </model>
    <!-- ================= END: YAML Defined Object ================= -->

    <!-- ================= START: NEW ADDED OBJECT ================= -->
    <!-- 新物块：X 和 Y 不变，Z 轴抬高至 1.0 以防初始重叠，颜色改为红色以便区分 -->
    <model name='target_plate_new'>
      <pose>0.43915 -0.12652 0.825 0 0 0</pose>
      <static>0</static>
      <link name='link_right'>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.04 0.1 0.1</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e+5</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.04 0.1 0.1</size>
            </box>
          </geometry>
          <material>
            <!-- 红色材质 -->
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.00033</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00017</iyy><iyz>0</iyz><izz>0.00017</izz>
          </inertia>
        </inertial>
      </link>
    </model>
    <!-- ================= END: NEW ADDED OBJECT ================= -->

    <!-- ================= START: ADDED TABLE FROM URDF ================= -->
    <model name='table_link'>
      <!-- 对应 URDF 中 joint world_to_table 的 xyz="0 0 0.75" -->
      <pose>0 0 0.75 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box>
              <size>2.0 1.6 0.05</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>100</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e+5</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>2.0 1.6 0.05</size>
            </box>
          </geometry>
          <material>
            <!-- 对应 URDF 中 rgba="0.5 0.5 0.5 1.0" -->
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <!-- 对应 URDF 中 mass="10.0" -->
          <mass>10.0</mass>
          <inertia>
            <ixx>1.0</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
            <iyy>1.0</iyy><iyz>0.0</iyz><izz>1.0</izz>
          </inertia>
        </inertial>
      </link>
    </model>
    <!-- ================= END: ADDED TABLE FROM URDF ================= -->


<!-- ================= START: FIVE-PART BOX CONTAINER WITH PURPLE BASE (UPDATED AGAIN) ================= -->
<model name='five_part_box_container'>
  <!-- 整体位置设置为Y=0.12，整体高度设置为 0.825，与现有物块对齐 -->
  <pose>0 0.12 0.825 0 0 0</pose>
  <static>1</static>
  
  <!-- 紫色底板 -->
  <link name='base_plate'>
    <pose>0 0 -0.005 0 0 0</pose> <!-- 底板厚度 0.01，所以 Z 坐标为 -0.005，使顶部在 Z=0.825 平面 -->
    <collision name='collision_base'>
      <geometry>
        <box>
          <size>0.3 0.3 0.01</size> <!-- 底板厚度改为 0.01m -->
        </box>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e+5</kp>
            <kd>100</kd>
          </ode>
        </contact>
      </surface>
    </collision>
    <visual name='visual_base'>
      <geometry>
        <box>
          <size>0.3 0.3 0.01</size>
        </box>
      </geometry>
      <material>
        <ambient>0.6 0.2 0.8 1</ambient>  <!-- 紫色 -->
        <diffuse>0.6 0.2 0.8 1</diffuse>  <!-- 紫色 -->
        <specular>0.2 0.2 0.2 1</specular>
      </material>
    </visual>
    <inertial>
      <mass>0.5</mass>
      <inertia>
        <ixx>0.005</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.005</iyy><iyz>0</iyz><izz>0.005</izz>
      </inertia>
    </inertial>
  </link>
  
  <!-- 左侧墙壁 -->
  <link name='left_wall'>
    <pose>-0.15 0 0.005 0 0 0</pose> <!-- Z 坐标调整为 0.005，因为底板厚度变为 0.01 -->
    <collision name='collision_left'>
      <geometry>
        <box>
          <size>0.01 0.3 0.1</size> <!-- 墙壁厚度 0.01m，高度 0.1m -->
        </box>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e+5</kp>
            <kd>100</kd>
          </ode>
        </contact>
      </surface>
    </collision>
    <visual name='visual_left'>
