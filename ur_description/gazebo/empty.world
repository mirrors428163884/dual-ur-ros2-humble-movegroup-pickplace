  </link>
  
  <!-- 后侧墙壁 -->
  <link name='back_wall'>
    <pose>0 0.15 0.005 0 0 0</pose> <!-- Z 坐标调整为 0.005，因为底板厚度变为 0.01 -->
    <collision name='collision_back'>
      <geometry>
        <box>
          <size>0.3 0.01 0.1</size> <!-- 墙壁厚度 0.01m，高度 0.1m -->
        </box>
      </geometry>
