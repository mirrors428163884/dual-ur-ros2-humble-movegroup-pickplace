    </inertial>
  </link>
  
  <!-- 前侧墙壁 -->
  <link name='front_wall'>
    <pose>0 -0.15 0.005 0 0 0</pose> <!-- Z 坐标调整为 0.005，因为底板厚度变为 0.01 -->
    <collision name='collision_front'>
