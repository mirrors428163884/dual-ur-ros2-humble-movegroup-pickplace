      <mass value="4.268588744e-02"/>
      <inertia ixx="1.048152e-05" ixy="0.0" ixz="3.5232e-6" iyy="1.197888e-05" iyz="0.0" izz="4.22784e-06"/>
    </inertial>
  </link>
  <link name="right_robotiq_85_right_finger_tip_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find robotiq_description)/meshes/visual/2f_85/right_finger_tip.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find robotiq_description)/meshes/collision/2f_85/right_finger_tip.stl"/>
      </geometry>
      <surface>
