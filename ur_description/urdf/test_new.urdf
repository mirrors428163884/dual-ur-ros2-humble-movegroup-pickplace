    <inertial>
      <origin rpy="0 0 0" xyz="0.01456706 5e-05 0.01649701"/>
      <mass value="4.268588744e-02"/>
      <inertia ixx="1.048152e-05" ixy="0.0" ixz="-3.5232e-06" iyy="1.197888e-05" iyz="0.0" izz="4.22784e-06"/>
    </inertial>
  </link>
  <joint name="right_robotiq_85_base_joint" type="fixed">
    <parent link="right_camera_baselink"/>
    <child link="right_robotiq_85_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <joint name="right_robotiq_85_left_knuckle_joint" type="revolute">
    <parent link="right_robotiq_85_base_link"/>
    <child link="right_robotiq_85_left_knuckle_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.03060114 0.0 0.05490452"/>
    <limit effort="50" lower="0.0" upper="0.8" velocity="0.5"/>
  </joint>
  <joint name="right_robotiq_85_right_knuckle_joint" type="revolute">
    <parent link="right_robotiq_85_base_link"/>
    <child link="right_robotiq_85_right_knuckle_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="-0.03060114 0.0 0.05490452"/>
    <limit effort="50" lower="-0.8" upper="0.0" velocity="0.5"/>
    <mimic joint="right_robotiq_85_left_knuckle_joint" multiplier="-1"/>
  </joint>
  <joint name="right_robotiq_85_left_finger_joint" type="fixed">
    <parent link="right_robotiq_85_left_knuckle_link"/>
    <child link="right_robotiq_85_left_finger_link"/>
    <origin rpy="0 0 0" xyz="0.03152616 0.0 -0.00376347"/>
  </joint>
  <joint name="right_robotiq_85_right_finger_joint" type="fixed">
    <parent link="right_robotiq_85_right_knuckle_link"/>
    <child link="right_robotiq_85_right_finger_link"/>
    <origin rpy="0 0 0" xyz="-0.03152616 0.0 -0.00376347"/>
  </joint>
  <joint name="right_robotiq_85_left_inner_knuckle_joint" type="continuous">
    <parent link="right_robotiq_85_base_link"/>
    <child link="right_robotiq_85_left_inner_knuckle_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.0127 0.0 0.06142"/>
    <mimic joint="right_robotiq_85_left_knuckle_joint"/>
  </joint>
  <joint name="right_robotiq_85_right_inner_knuckle_joint" type="continuous">
    <parent link="right_robotiq_85_base_link"/>
    <child link="right_robotiq_85_right_inner_knuckle_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="-0.0127 0.0 0.06142"/>
    <mimic joint="right_robotiq_85_left_knuckle_joint" multiplier="-1"/>
  </joint>
  <joint name="right_robotiq_85_left_finger_tip_joint" type="continuous">
    <parent link="right_robotiq_85_left_finger_link"/>
    <child link="right_robotiq_85_left_finger_tip_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.00563134 0.0 0.04718515"/>
    <mimic joint="right_robotiq_85_left_knuckle_joint" multiplier="-1"/>
  </joint>
  <joint name="right_robotiq_85_right_finger_tip_joint" type="continuous">
    <parent link="right_robotiq_85_right_finger_link"/>
    <child link="right_robotiq_85_right_finger_tip_link"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="-0.00563134 0.0 0.04718515"/>
    <mimic joint="right_robotiq_85_left_knuckle_joint"/>
  </joint>
  <joint name="left_camera_basejoint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="left_tool0"/>
    <child link="left_camera_baselink"/>
    <axis xyz="0 0 0"/>
  </joint>
  <joint name="right_camera_basejoint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="right_tool0"/>
    <child link="right_camera_baselink"/>
    <axis xyz="0 0 0"/>
  </joint>

  <gazebo reference="left_robotiq_85_base_link">
    <!-- No specific plugins needed here, just the reference is enough to register the link in Gazebo's physics engine. -->
  </gazebo>
  
  <gazebo reference="right_robotiq_85_base_link">
    <!-- No specific plugins needed here, just the reference is enough to register the link in Gazebo's physics engine. -->
  </gazebo>

  <!-- START 虚拟 Mimic 关节定义 以下为完全孤立的虚拟结构，用于欺骗 MoveIt 认为这些关节存在  -->
  <!-- 1. 创建一个统一的虚拟根连杆，用于挂载所有修复用的假关节 -->
  <link name="moveit_mimic_fix_dummy_root">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
      <material name="transparent">
        <color rgba="0 0 0 0"/>
      </material>
    </visual>
  </link>

  <!-- 2. 将这个统一根连杆固定到真实的 world 连杆上 (确保单根结构) -->
  <joint name="moveit_mimic_fix_to_world" type="fixed">
    <parent link="world"/>
    <child link="moveit_mimic_fix_dummy_root"/>
    <origin xyz="0 0 -10.0"/> 
  </joint>

  <!-- === Left Gripper Virtual Joints (挂在 dummy_root 下) === -->

  <!-- 1. left_robotiq_85_right_knuckle_joint_mimic -->
  <link name="dummy_child_l_r_knuckle"/>
  <joint name="left_robotiq_85_right_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_l_r_knuckle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 2. left_robotiq_85_left_inner_knuckle_joint_mimic -->
  <link name="dummy_child_l_l_inner"/>
  <joint name="left_robotiq_85_left_inner_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_l_l_inner"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 3. left_robotiq_85_right_inner_knuckle_joint_mimic -->
  <link name="dummy_child_l_r_inner"/>
  <joint name="left_robotiq_85_right_inner_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_l_r_inner"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 4. left_robotiq_85_left_finger_tip_joint_mimic -->
  <link name="dummy_child_l_l_tip"/>
  <joint name="left_robotiq_85_left_finger_tip_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_l_l_tip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 5. left_robotiq_85_right_finger_tip_joint_mimic -->
  <link name="dummy_child_l_r_tip"/>
  <joint name="left_robotiq_85_right_finger_tip_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_l_r_tip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- === Right Gripper Virtual Joints (挂在 dummy_root 下) === -->

  <!-- 6. right_robotiq_85_right_knuckle_joint_mimic -->
  <link name="dummy_child_r_r_knuckle"/>
  <joint name="right_robotiq_85_right_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_r_r_knuckle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 7. right_robotiq_85_left_inner_knuckle_joint_mimic -->
  <link name="dummy_child_r_l_inner"/>
  <joint name="right_robotiq_85_left_inner_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_r_l_inner"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 8. right_robotiq_85_right_inner_knuckle_joint_mimic -->
  <link name="dummy_child_r_r_inner"/>
  <joint name="right_robotiq_85_right_inner_knuckle_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_r_r_inner"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 9. right_robotiq_85_left_finger_tip_joint_mimic -->
  <link name="dummy_child_r_l_tip"/>
  <joint name="right_robotiq_85_left_finger_tip_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_r_l_tip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 10. right_robotiq_85_right_finger_tip_joint_mimic -->
  <link name="dummy_child_r_r_tip"/>
  <joint name="right_robotiq_85_right_finger_tip_joint_mimic" type="fixed">
    <parent link="moveit_mimic_fix_dummy_root"/>
    <child link="dummy_child_r_r_tip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <!-- END 虚拟 Mimic 关节定义修正  -->


<gazebo>
  <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
    <parameters>$(find dual_ur_moveit_config)/config/ros2_controllers.yaml</parameters>
  </plugin>
</gazebo>

</robot>
