  <ros2_control name="right_gripper" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <!-- 主驱动关节 -->
    <joint name="right_robotiq_85_left_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.7929</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <!-- Mimic joints (no command_interface in Gazebo) -->
    <joint name="right_robotiq_85_right_knuckle_joint">
      <param name="mimic">right_robotiq_85_left_knuckle_joint</param>
      <param name="multiplier">-1</param>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_robotiq_85_left_inner_knuckle_joint">
      <param name="mimic">right_robotiq_85_left_knuckle_joint</param>
      <param name="multiplier">1</param>
